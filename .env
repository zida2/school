# Configuration Docker pour UniERP BF
# Copier ce fichier en .env et modifier les valeurs

# ===== DJANGO =====
SECRET_KEY=django-insecure-CHANGEZ-MOI-EN-PRODUCTION-utilisez-python-manage-py-shell-get-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,votre-domaine.com

# ===== BASE DE DONNÉES =====
DB_NAME=erp_universitaire
DB_USER=postgres
DB_PASSWORD=postgres_password_securise
DB_HOST=db
DB_PORT=5432

# ===== ADMIN PAR DÉFAUT =====
ADMIN_EMAIL=admin@unierp.bf
ADMIN_PASSWORD=Admin2026

# ===== CORS (Frontend URLs) =====
CORS_ORIGINS=http://localhost:3000,https://votre-frontend.com

# ===== JWT =====
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ===== EMAIL (Optionnel) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app
