# Configuration pour la production
# Copier ce fichier en .env et remplir les valeurs

# Django
SECRET_KEY=votre-secret-key-super-securisee-a-generer
DEBUG=False
ALLOWED_HOSTS=votre-username.pythonanywhere.com,localhost,127.0.0.1

# Base de données (SQLite par défaut)
DATABASE_URL=sqlite:///db.sqlite3

# Pour PostgreSQL (Railway, Render, Docker, etc.)
# DATABASE_URL=postgresql://user:password@host:port/database
DB_NAME=erp_universitaire
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# CORS (Frontend URL)
CORS_ORIGINS=https://votre-app.vercel.app,http://localhost:8080
FRONTEND_URL=https://votre-app.vercel.app

# Email (IMPORTANT pour l'envoi des identifiants)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app-gmail
DEFAULT_FROM_EMAIL=noreply@unierp.bf

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Admin par défaut
ADMIN_EMAIL=admin@unierp.bf
ADMIN_PASSWORD=Admin2026
